#!/usr/bin/env ruby

require "bundler/setup"
require_relative "../lib/solr_indexer"
require "benchmark"

CONFIG_FILE_NAME = File.expand_path(File.join("..", "config.yml"), __dir__)
config = YAML.load(ERB.new(File.read(CONFIG_FILE_NAME)).result, aliases: true)

submitter = {
  "messy" => SolrIndexer::Submitter.new(config["submitter"]),
  "tidy" => SolrIndexer::Submitter.new(config["submitter"].merge("delete" => 0.2)),
  "complete" => SolrIndexer::Submitter.new(config["submitter"].merge("delete" => 1.1))
}

if [
  SolrIndexer::XML.new(config["specialty_sites"], submitter).submit,
  SolrIndexer::OnlineExhibits.new(config["online_exhibits"], submitter).submit,
  SolrIndexer::Blogs.new(config["blogs"], submitter).submit,
  SolrIndexer::Staff.new(config["staff"], submitter).submit,
  SolrIndexer::LibGuides.new(config["libguides"], submitter).submit,
  SolrIndexer::Microsites.new(config["microsites"], submitter).submit
].any?(&:failed?)
  exit(1)
end
